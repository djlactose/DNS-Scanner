# Secrets (leave empty to auto-generate)
DB_PASSWORD=
REDIS_PASSWORD=
SESSION_SECRET=
ENCRYPTION_KEY=

# Database
DB_NAME=dnsscanner
DB_USER=dnsscanner

# App
APP_PORT=8080
REGISTRATION_ENABLED=true
ALLOW_PRIVATE_RANGES=false
MAX_DOMAINS=50

# Storage (host paths for bind mounts)
DATA_PATH=/srv/dnsscanner
