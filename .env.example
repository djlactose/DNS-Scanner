# Database
DB_HOST=db
DB_PORT=5432
DB_NAME=dnsscanner
DB_USER=dnsscanner
DB_PASSWORD=change_me_to_a_strong_password

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_me_to_a_strong_password

# Session
SESSION_SECRET=change_me_to_a_random_string_at_least_32_chars

# Encryption key for SMTP credentials (AES-256-GCM, must be 32+ chars)
ENCRYPTION_KEY=change_me_to_a_random_string_at_least_32_chars

# App
PORT=8080
NODE_ENV=production

# Registration (set to false after initial setup)
REGISTRATION_ENABLED=true

# SSRF protection (set to true to allow scanning private IP ranges)
ALLOW_PRIVATE_RANGES=false

# Max domains per instance
MAX_DOMAINS=50
