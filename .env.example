# Database
DB_HOST=db
DB_PORT=5432
DB_NAME=dnsscanner
DB_USER=dnsscanner
DB_PASSWORD=change_me_to_a_strong_password

# Session
SESSION_SECRET=change_me_to_a_random_string_at_least_32_chars

# Encryption key for SMTP credentials (AES-256-GCM, must be 32+ chars)
ENCRYPTION_KEY=change_me_to_a_random_string_at_least_32_chars

# App
PORT=8080
NODE_ENV=production

# Registration: keep false in production. To bootstrap the first (admin)
# user, temporarily set to true, register, then set back to false and
# restart the app.
REGISTRATION_ENABLED=false

# SSRF protection (set to true to allow scanning private IP ranges)
ALLOW_PRIVATE_RANGES=false

# Max domains per instance
MAX_DOMAINS=50

# Google OAuth (optional - leave blank to disable Google Sign-In)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# WebAuthn / Passkey settings (auto-detected from Host header if not set)
# WEBAUTHN_RP_ID=scanner.example.com
# WEBAUTHN_RP_NAME=DNS Scanner
# WEBAUTHN_ORIGIN=https://scanner.example.com
